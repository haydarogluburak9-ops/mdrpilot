{
  "name": "mdrpilot",
  "version": "0.1.0",
  "private": true,
  "description": "MDRpilot - AI-assisted MDR / ISO 13485 / ISO 9001 technical documentation platform for medical device manufacturers",
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File scripts/dev.ps1",
    "dev:clean": "powershell -ExecutionPolicy Bypass -Command \"if (Test-Path .next) { Remove-Item -Recurse -Force .next }; & scripts/dev.ps1\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:sync-standards": "tsx scripts/sync-standards.ts",
    "db:sync-qms": "tsx scripts/sync-qms.ts",
    "db:sync-dossier": "tsx scripts/sync-product-dossier.ts",
    "db:sync-applicability": "tsx scripts/sync-applicability.ts",
    "db:bootstrap-kys": "tsx scripts/bootstrap-kys-pack.ts",
    "db:studio": "prisma studio",
    "test:isolation": "tsx scripts/test-isolation.ts",
    "test:exports": "powershell -ExecutionPolicy Bypass -File scripts/test-exports.ps1",
    "test:files": "tsx scripts/test-files.ts",
    "test:composer": "tsx scripts/test-composer.ts",
    "test:standards": "tsx scripts/test-standards.ts",
    "test:qm-wizard": "tsx scripts/test-quality-manual-wizard.ts",
    "test:consultant-audit": "tsx scripts/test-consultant-audit.ts",
    "test:demo": "tsx scripts/test-demo.ts",
    "offload:d": "powershell -ExecutionPolicy Bypass -File scripts/offload-to-d.ps1"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "bwip-js": "^4.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx": "^8.5.0",
    "exceljs": "^4.4.0",
    "framer-motion": "^11.11.17",
    "jszip": "^3.10.1",
    "lucide-react": "^0.460.0",
    "mammoth": "^1.12.0",
    "next": "^14.2.33",
    "otplib": "^13.4.1",
    "pdf-parse": "^1.1.4",
    "pdfkit": "^0.15.2",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3",
    "server-only": "^0.0.1",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.17.6",
    "@types/pdf-parse": "^1.1.5",
    "@types/pdfkit": "^0.13.9",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.18",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
