# ============================================================
# MDRpilot - Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit the real .env file. NEVER expose secrets to the client.
# ============================================================

# --- App ---
NODE_ENV=development
APP_URL=http://localhost:3000
APP_NAME="MDRpilot"

# --- Database (PostgreSQL) ---
# Example: postgresql://USER:PASSWORD@HOST:5432/meddoc?schema=public
# Quick start with Docker (host port 5433 to avoid clashing with a local Postgres):
#   docker run -d --name meddoc-postgres -e POSTGRES_USER=meddoc -e POSTGRES_PASSWORD=meddoc -e POSTGRES_DB=meddoc -p 5433:5432 postgres:16-alpine
DATABASE_URL="postgresql://meddoc:meddoc@localhost:5433/meddoc?schema=public"

# --- Auth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"
SESSION_COOKIE_NAME="mdrpilot_session"
SESSION_MAX_AGE_HOURS=8
# End session after this many minutes without activity (default 30). Also set NEXT_PUBLIC_SESSION_IDLE_MINUTES for the browser guard.
SESSION_IDLE_MINUTES=30
NEXT_PUBLIC_SESSION_IDLE_MINUTES=30
# Secure session cookies (default true in production). Set false only for local prod builds over HTTP.
# COOKIE_SECURE=true

# Production security
# Demo login banner + pre-filled credentials: NEVER enable in production.
# NEXT_PUBLIC_DEMO_MODE=false
# Require verified email before company-scoped APIs (default true in production).
# REQUIRE_EMAIL_VERIFICATION=true

# Platform owner panel (/admin) — comma-separated emails, server-only.
# Example: ADMIN_EMAILS="you@company.com,partner@company.com"
ADMIN_EMAILS=""

# --- AI Provider ---
# Server-only. Leave AI_PROVIDER=mock to run fully offline with the deterministic engine.
# Supported: mock | openai | anthropic
AI_PROVIDER=mock
# Generic key (used if the provider-specific key below is not set).
AI_API_KEY=""               # server-only, never exposed to the browser
# Provider-specific keys (preferred; also enable side-by-side provider comparison in /evaluation):
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
# OpenAI (or OpenAI-compatible gateway):
AI_BASE_URL="https://api.openai.com/v1"
# AI_MODEL examples: gpt-4o-mini, gpt-4o, gpt-5  (OpenAI) | claude, claude-3-5-sonnet-latest (Anthropic)
AI_MODEL="gpt-4o-mini"
# Anthropic (Claude):
ANTHROPIC_BASE_URL="https://api.anthropic.com/v1"
ANTHROPIC_VERSION="2023-06-01"
AI_MAX_TOKENS=4000
AI_TEMPERATURE=0.2
# Hard timeout per AI call (ms); on timeout the request falls back to the deterministic engine.
AI_TIMEOUT_MS=60000

# --- Redis (optional, for rate limiting / job queue) ---
# When set, rateLimitAsync() uses Redis; otherwise in-memory fallback.
REDIS_URL=""

# --- File Upload ---
UPLOAD_MAX_MB=25
UPLOAD_ALLOWED_MIME="application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,image/png,image/jpeg"
# Local dev storage. In production use a private bucket (S3/GCS) with signed URLs.
STORAGE_DRIVER=local        # local | s3
STORAGE_LOCAL_DIR="./storage/uploads"
# Generated export artifacts (DOCX/XLSX/PDF/ZIP). Private — served only via /api/exports/[id]/download.
STORAGE_EXPORTS_DIR="./storage/exports"
# S3 / MinIO / R2 (when STORAGE_DRIVER=s3):
# STORAGE_S3_BUCKET="mdrpilot-private"
# STORAGE_S3_REGION="eu-central-1"
# STORAGE_S3_ENDPOINT=""          # optional (MinIO/R2); leave empty for AWS
# STORAGE_S3_FORCE_PATH_STYLE=false
# STORAGE_S3_UPLOADS_PREFIX="uploads"
# STORAGE_S3_EXPORTS_PREFIX="exports"
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""

# --- Email (verification, password reset, team invites) ---
EMAIL_FROM="MDRpilot <noreply@mdrpilot.com>"
RESEND_API_KEY=""
SUPPORT_EMAIL="support@mdrpilot.com"

# --- Rate limiting ---
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_MAX_REQUESTS=120
