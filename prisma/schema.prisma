// ---------------- QMS (ISO 13485 / ISO 9001) ----------------

model QMSDocument {
  id           String            @id @default(cuid())
  companyId    String
  code         String? // QM-01, SOP-DC-01 ...
  title        String
  standard     String // ISO 13485 | ISO 9001
  layer        QmsDocumentLayer @default(PROCEDURE)
  parentProcedureCode String? // parent SOP code for forms, WI, diagrams, etc.
  linkedProcedureCodesJson Json? // e.g. ["SOP-AN","SOP-VG"] — same doc shown under multiple procedures
  clauseRefs   String? // "4.2.3, 7.5.1"
  status       DocStatus         @default(MISSING)
  preparedBy   String?
  approvedBy   String?
  version      String            @default("REV00")
  revisionNo   Int               @default(0)
  issueDate    DateTime?         // first approved issue date
  revisionDate DateTime?
  revisionHistoryJson Json?
  publishedAt  DateTime?
  reviewDueDate    DateTime?         // periodic document review (ISO 4.2.4)
  sourceFileId     String?           // last controlled upload source
  content      String?           @db.Text
  contentTranslationsJson Json?  // legacy; prefer ExportTranslationCache
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  deletedAt    DateTime?

  company      Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  revisions    QmsDocumentRevision[]

  @@index([companyId])
  @@index([companyId, parentProcedureCode])
  @@index([companyId, reviewDueDate])
}

model QmsDocumentRevision {
  id           String   @id @default(cuid())
  documentId   String
  revisionNo   Int
  version      String
  content      String   @db.Text
  changeNote   String?
  preparedBy   String?
  sourceFileId String?
  createdAt    DateTime @default(now())

  document     QMSDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, revisionNo])
  @@index([documentId])
}

// ---------------- Files ----------------

model UploadedFile {
  id             String             @id @default(cuid())
  companyId      String
  productId      String?
  uploadedById   String?
  originalName   String?
  storedName     String?
  fileName       String // display name (kept for backward compatibility)
  storageKey     String // private storage reference
  mimeType       String
  extension      String?
  sizeBytes      Int
  checksumSha256 String?
  documentKind   DocumentKind       @default(OTHER)
  category       String? // legacy free-text category
  textExtract    String?            @db.Text
  analysisSummary String?           @db.Text
  analysisJson   Json?
  analysisStatus FileAnalysisStatus @default(PENDING)
  aiSummary      String?            @db.Text
  linkedGsprNo   String?
  createdAt      DateTime           @default(now())
  deletedAt      DateTime?

  company        Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product        Product?           @relation(fields: [productId], references: [id], onDelete: SetNull)
  gsprLinks          GSPREvidenceLink[]
  technicalFileLinks TechnicalFileEvidenceLink[]
  riskLinks          RiskEvidenceLink[]
  riskMgmtPlanFiles    RiskManagementFile[] @relation("RiskMgmtPlanFile")
  riskMgmtReportFiles  RiskManagementFile[] @relation("RiskMgmtReportFile")
  riskMgmtPolicyFiles  RiskManagementFile[] @relation("RiskMgmtPolicyFile")

  @@index([companyId])
  @@index([productId])
  @@index([checksumSha256])
}

model GSPREvidenceLink {
  id             String       @id @default(cuid())
  companyId      String
  productId      String
  gsprItemId     String
  uploadedFileId String
  linkedById     String?
  note           String?
  createdAt      DateTime     @default(now())

  gsprItem       GSPRItem     @relation(fields: [gsprItemId], references: [id], onDelete: Cascade)
  uploadedFile   UploadedFile @relation(fields: [uploadedFileId], references: [id], onDelete: Cascade)

  @@unique([gsprItemId, uploadedFileId])
  @@index([companyId])
  @@index([productId])
}

model TechnicalFileEvidenceLink {
  id                     String               @id @default(cuid())
  companyId              String
  productId              String
  technicalFileSectionId String
  uploadedFileId         String
  linkedById             String?
  note                   String?
  createdAt              DateTime             @default(now())

  technicalFileSection   TechnicalFileSection @relation(fields: [technicalFileSectionId], references: [id], onDelete: Cascade)
  uploadedFile           UploadedFile         @relation(fields: [uploadedFileId], references: [id], onDelete: Cascade)

  @@unique([technicalFileSectionId, uploadedFileId])
  @@index([companyId])
  @@index([productId])
}

model RiskEvidenceLink {
  id             String       @id @default(cuid())
  companyId      String
  productId      String
  riskItemId     String
  uploadedFileId String
  linkedById     String?
  note           String?
  createdAt      DateTime     @default(now())

  riskItem       RiskItem     @relation(fields: [riskItemId], references: [id], onDelete: Cascade)
  uploadedFile   UploadedFile @relation(fields: [uploadedFileId], references: [id], onDelete: Cascade)

  @@unique([riskItemId, uploadedFileId])
  @@index([companyId])
  @@index([productId])
}

