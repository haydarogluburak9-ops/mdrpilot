// ============================================================
// MedDoc AI - Prisma schema
// MDR 2017/745 / ISO 13485 / ISO 9001 / ISO 14971 documentation platform
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------- Enums ----------------

enum CompanyRole {
  OWNER
  QUALITY_MANAGER
  REGULATORY_AFFAIRS
  CONSULTANT
  VIEWER
}

enum DeviceClass {
  CLASS_I
  CLASS_IS
  CLASS_IM
  CLASS_IR
  CLASS_IIA
  CLASS_IIB
  CLASS_III
}

enum SterilizationMethod {
  NON_STERILE
  EO
  GAMMA
  STEAM
  OTHER
}

enum DocStatus {
  MISSING
  DRAFT
  IN_REVIEW
  APPROVED
  REJECTED
}

// ISO 13485 KYS folder layers (01 manual, 02 procedures, ...)
enum QmsDocumentLayer {
  MANUAL
  PROCEDURE
  OTHER
  PLAN
  DIAGRAM
  LIST
  SPECIFICATION
  JOB_DESCRIPTION
  INSTRUCTION
  FORM
  ASSIGNMENT
  RECORD
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum GsprApplicability {
  YES
  NO
  JUSTIFICATION
}

enum CapaStatus {
  OPEN
  IN_PROGRESS
  CLOSED
  OVERDUE
}

enum ComplaintStatus {
  OPEN
  MONITORING
  CLOSED
}

enum OperationalRecordStatus {
  OPEN
  IN_PROGRESS
  CLOSED
  OVERDUE
  MONITORING
}

enum OperationalModuleKind {
  INTERNAL_AUDIT
  NCP
  FSCA
  VIGILANCE
  CHANGE_CONTROL
  MANAGEMENT_REVIEW
  TRAINING
  SUPPLIER_EVAL
  TRACEABILITY
  CALIBRATION
}

enum DocumentReviewStepRole {
  REVIEWER
  APPROVER
  RELEASE
}

enum DocumentReviewStepStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AuditSeverity {
  MINOR
  MAJOR
  CRITICAL
  OBSERVATION
}

enum ExportType {
  TECHNICAL_FILE_DOCX
  FULL_MDR_TECHNICAL_FILE_ZIP
  GSPR_XLSX
  RISK_XLSX
  IFU_DOCX
  LABEL_PDF
  PMS_PMCF_DOCX
  QMS_PACKAGE_ZIP
  AUDIT_READINESS_PDF
  PRODUCT_DOSSIER_ZIP
  COMPOSER_DOCUMENT_DOCX
  COMPOSER_DOCUMENT_PDF
  DEMO_EXECUTIVE_REPORT_PDF
  AUDIT_SIM_REPORT_PDF
  AUDIT_SIM_REPORT_DOCX
  AUDIT_SIM_FINDINGS_XLSX
  AUDIT_SIM_CAPA_XLSX
  DHF_DOCX
  DHF_PDF
}

enum ExportFormat {
  WORD
  PDF
  EXCEL
  ZIP
}

enum ExportStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum AiAnalysisType {
  TECHNICAL_FILE
  GSPR
  RISK
  IFU
  CER
  PMS
  QMS
  AUDIT_READINESS
  FILE_ANALYSIS
}

enum DocumentKind {
  TEST_REPORT
  IFU
  LABEL
  CERTIFICATE
  RISK_FILE
  CLINICAL_EVALUATION
  PMS
  PMCF
  GSPR_EVIDENCE
  TECHNICAL_DRAWING
  OTHER
}

enum FileAnalysisStatus {
  PENDING
  COMPLETED
  FAILED
}

enum DocumentComposerType {
  ISO13485_QUALITY_MANUAL
  ISO9001_QUALITY_MANUAL
  ISO13485_DOCUMENT_CONTROL_PROCEDURE
  ISO13485_CAPA_PROCEDURE
  ISO13485_INTERNAL_AUDIT_PROCEDURE
  ISO13485_MANAGEMENT_REVIEW_PROCEDURE
  ISO13485_RISK_MANAGEMENT_PROCEDURE
  MDR_TECHNICAL_FILE_NARRATIVE
  MDR_DECLARATION_OF_CONFORMITY_DRAFT
  MDR_GSPR_COMPLIANCE_STATEMENT
  ISO14971_RISK_MANAGEMENT_PLAN
  ISO14971_RISK_MANAGEMENT_REPORT
  PMS_PLAN
  PMCF_PLAN
  PMCF_EVALUATION_REPORT
  CLINICAL_EVALUATION_PLAN
  CLINICAL_EVALUATION_REPORT_DRAFT
  IFU_DRAFT
  LABELING_TEXT_DRAFT
  SUPPLIER_EVALUATION_PROCEDURE
  STERILIZATION_CONTROL_PROCEDURE
  COMPLAINT_HANDLING_PROCEDURE
  VIGILANCE_PROCEDURE
  CHANGE_CONTROL_PROCEDURE
  TRAINING_PROCEDURE
}

enum ComposerStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

model ComposerDocument {
  id                      String               @id @default(cuid())
  companyId               String
  productId               String?
  createdById             String?
  approvedById            String?
  title                   String
  type                    DocumentComposerType
  status                  ComposerStatus       @default(DRAFT)
  version                 Int                  @default(1)
  contentJson             Json?
  contentMarkdown         String               @db.Text
  sourceSnapshotJson      Json?
  aiModel                 String?
  aiConfidence            Float                @default(0)
  missingInformationJson  Json?
  complianceGapsJson      Json?
  consistencyWarningsJson Json?
  evidenceUsedJson        Json?
  disclaimer              String?              @db.Text
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  approvedAt              DateTime?
  archivedAt              DateTime?

  company                 Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product                 Product?             @relation(fields: [productId], references: [id], onDelete: SetNull)
  versions                ComposerDocumentVersion[]

  @@index([companyId])
  @@index([productId])
}

model ComposerDocumentVersion {
  id                 String           @id @default(cuid())
  composerDocumentId String
  version            Int
  contentJson        Json?
  contentMarkdown    String           @db.Text
  changeSummary      String?
  createdById        String?
  createdAt          DateTime         @default(now())

  document           ComposerDocument @relation(fields: [composerDocumentId], references: [id], onDelete: Cascade)

  @@index([composerDocumentId])
}

// ---------------- Standards Knowledge Base / RAG ----------------

enum StandardSourceType {
  PUBLIC_REGULATION
  USER_UPLOADED_LICENSED
  INTERNAL_PROCEDURE
  TEMPLATE_SUMMARY
}

enum CitationTargetType {
  COMPOSER_DOCUMENT
  AI_ANALYSIS
  AUDIT_FINDING
  FILE_ANALYSIS
}

model Standard {
  id           String             @id @default(cuid())
  companyId    String?
  code         String
  title        String
  version      String?
  sourceType   StandardSourceType @default(TEMPLATE_SUMMARY)
  jurisdiction String?
  isPublic     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  company      Company?           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clauses      StandardClause[]

  @@index([companyId])
  @@index([code])
}

model StandardClause {
  id                       String   @id @default(cuid())
  standardId               String
  clauseNo                 String
  title                    String
  summary                  String   @db.Text
  keywords                 String?
  applicability            String?
  documentExpectationsJson Json?
  evidenceExpectationsJson Json?
  riskRelevanceJson        Json?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  standard                 Standard @relation(fields: [standardId], references: [id], onDelete: Cascade)

  @@index([standardId])
}

model KnowledgeChunk {
  id             String             @id @default(cuid())
  companyId      String?
  standardId     String?
  uploadedFileId String?
  sourceType     StandardSourceType @default(TEMPLATE_SUMMARY)
  title          String
  text           String             @db.Text
  embeddingJson  Json?
  metadataJson   Json?
  createdAt      DateTime           @default(now())

  @@index([companyId])
  @@index([standardId])
  @@index([uploadedFileId])
}

model AICitation {
  id             String             @id @default(cuid())
  companyId      String
  targetType     CitationTargetType
  targetId       String
  standardId     String?
  clauseId       String?
  uploadedFileId String?
  quoteSnippet   String?
  summary        String
  confidence     Float              @default(0)
  createdAt      DateTime           @default(now())

  @@index([companyId])
  @@index([targetType, targetId])
}

// ---------------- Quality Manual Wizard ----------------

enum QualityManualWizardStatus {
  DRAFT
  GAP_CHECKED
  GENERATED
  ARCHIVED
}

enum QualityManualStandardMode {
  ISO_9001
  ISO_13485
  BOTH
}

// ---------------- Audit Simulator ----------------

enum AuditStandardScope {
  MDR
  ISO_13485
  ISO_9001
  ISO_14971
  COMBINED
}

enum AuditAssessmentType {
  QUICK
  STANDARD
  FULL
}

enum AuditSessionStatus {
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum AuditFindingSeverity {
  MAJOR
  MINOR
  OBSERVATION
  POSITIVE
}

model AuditSession {
  id             String              @id @default(cuid())
  companyId      String
  productId      String?
  createdById    String?
  standard       AuditStandardScope  @default(ISO_13485)
  assessmentType AuditAssessmentType @default(STANDARD)
  status         AuditSessionStatus  @default(IN_PROGRESS)
  score          Int?
  summaryJson    Json?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  completedAt    DateTime?

  company        Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product        Product?            @relation(fields: [productId], references: [id], onDelete: SetNull)
  questions      AuditQuestion[]
  answers        AuditAnswer[]
  findings       AuditSimFinding[]

  @@index([companyId])
  @@index([productId])
}

model AuditQuestion {
  id            String       @id @default(cuid())
  sessionId     String
  order         Int
  standardCode  String
  clauseNo      String
  question      String       @db.Text
  expectedEvidence String?   @db.Text
  createdAt     DateTime     @default(now())

  session       AuditSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  answer        AuditAnswer?

  @@index([sessionId])
}

model AuditAnswer {
  id              String        @id @default(cuid())
  sessionId       String
  questionId      String        @unique
  answerText      String        @db.Text
  evidenceFileIdsJson Json?
  createdById     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  session         AuditSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question        AuditQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model AuditSimFinding {
  id                String               @id @default(cuid())
  sessionId         String
  companyId         String
  standardCode      String
  clauseNo          String
  severity          AuditFindingSeverity @default(MINOR)
  description       String               @db.Text
  evidence          String?              @db.Text
  rootCause         String?              @db.Text
  correctiveAction  String?              @db.Text
  dueDateSuggestion DateTime?
  priority          Int                  @default(0)
  createdAt         DateTime             @default(now())

  session           AuditSession         @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([companyId])
}

model QualityManualWizardSession {
  id                 String                    @id @default(cuid())
  companyId          String
  createdById        String?
  composerDocumentId String?
  status             QualityManualWizardStatus @default(DRAFT)
  standardMode       QualityManualStandardMode @default(ISO_13485)
  currentStep        Int                       @default(1)
  answersJson        Json?
  gapCheckJson       Json?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  generatedAt        DateTime?

  company            Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

// ---------------- Core / Tenancy ----------------

enum AuthTokenType {
  EMAIL_VERIFY
  PASSWORD_RESET
}

model User {
  id           String          @id @default(cuid())
  email        String          @unique
  name         String?
  passwordHash String?
  avatarUrl    String?
  emailVerifiedAt   DateTime?
  termsAcceptedAt   DateTime?
  privacyAcceptedAt DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?

  memberships  CompanyMember[]
  auditLogs    AuditLog[]
  sessions     Session[]
  authTokens   AuthToken[]
  invitesSent  CompanyInvite[] @relation("InviteSender")
  clinicalEvaluationsSubmitted ClinicalEvaluation[] @relation("ClinicalEvaluationSubmittedBy")
  clinicalEvaluationsApproved  ClinicalEvaluation[] @relation("ClinicalEvaluationApprovedBy")
  documentApprovals            DocumentApproval[]
  documentReviewSteps          DocumentReviewStep[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  companyId String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Company {
  id                String            @id @default(cuid())
  name              String
  legalName         String?
  country           String?
  address           String?
  contactEmail      String? // manufacturer contact e-mail (TF / label)
  contactPhone      String? // manufacturer contact phone (TF / label)
  manufacturingSites String? // manufacturing site(s) name & address
  authorizedRep     String? // EU authorised representative (name & address)
  srnNumber         String? // Single Registration Number (EUDAMED)
  notifiedBody      String? // Notified Body name
  notifiedBodyNumber String? // Notified Body 4-digit number (e.g. 0123)
  profileJson       Json? // onboarding personalization (industry, standards, goal, product count)
  logoKey           String? // storage key of the uploaded company logo (private uploads storage)
  logoMime          String? // mime type of the logo (image/png | image/jpeg)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deletedAt         DateTime?

  subscriptionId    String?
  subscription      SubscriptionPlan? @relation(fields: [subscriptionId], references: [id])
  // Extra AI tokens purchased (do not reset monthly).
  extraAiTokens     Int               @default(0)
  // AI tokens consumed in the current billing period.
  aiTokensUsed      Int               @default(0)
  tokenPeriodStart  DateTime          @default(now())

  members           CompanyMember[]
  products          Product[]
  qmsDocuments      QMSDocument[]
  uploadedFiles     UploadedFile[]
  exportJobs        ExportJob[]
  auditLogs         AuditLog[]
  composerDocuments ComposerDocument[]
  standards         Standard[]
  qualityManualWizards QualityManualWizardSession[]
  auditSessions     AuditSession[]
  complaints        Complaint[]
  capas             CAPA[]
  operationalRecords QmsOperationalRecord[]
  internalAuditCycles InternalAuditCycle[]
  approvedSuppliers ApprovedSupplier[]
  documentApprovals DocumentApproval[]
  documentReviewSteps DocumentReviewStep[]
  trainingCompetencies TrainingCompetency[]
  invites           CompanyInvite[]
  supportTickets    SupportTicket[]
  aiTokenPurchases  AiTokenPurchase[]
}

model CompanyMember {
  id        String      @id @default(cuid())
  companyId String
  userId    String
  role      CompanyRole @default(VIEWER)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([companyId])
}

model SubscriptionPlan {
  id               String    @id @default(cuid())
  key              String    @unique // starter | basic | plus | pro | enterprise
  name             String
  priceMonthly     Int       @default(0)
  maxProducts      Int       @default(1)
  maxSeats         Int       @default(1)
  // Monthly AI token allowance (resets each period). 0 = mock-only unless extra purchased.
  monthlyAiTokens  Int       @default(0)
  features         Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  companies        Company[]
}

model AiTokenPurchase {
  id        String   @id @default(cuid())
  companyId String
  packKey   String
  tokens    Int
  amountEur Int
  createdAt DateTime @default(now())

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model AuthToken {
  id        String        @id @default(cuid())
  userId    String
  type      AuthTokenType
  token     String        @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime      @default(now())

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

model CompanyInvite {
  id          String      @id @default(cuid())
  companyId   String
  email       String
  role        CompanyRole @default(VIEWER)
  token       String      @unique
  invitedById String
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime    @default(now())

  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invitedBy   User        @relation("InviteSender", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([email])
}

model SupportTicket {
  id        String   @id @default(cuid())
  companyId String?
  userId    String?
  email     String
  name      String?
  subject   String
  message   String   @db.Text
  attachmentsJson Json? // [{ fileName, storageKey, mimeType, sizeBytes }]
  status    String   @default("open")
  createdAt DateTime @default(now())

  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([status])
}

// ---------------- Product / Device ----------------

model Product {
  id                String              @id @default(cuid())
  companyId         String
  name              String
  brand             String?
  model             String?
  variantsJson      Json? // device family matrix: brands -> models -> sterilization methods
  basicUdiDi        String?
  udiDi             String?
  emdnCode          String?             // EMDN (European Medical Device Nomenclature)
  eudamedDeviceId           String?
  eudamedRegistrationStatus String?           // NOT_REGISTERED | IN_PROGRESS | REGISTERED
  softwareSafetyClass       String?             // IEC 62304: A | B | C
  photoKey          String?             // default product image for exports (e.g. DoC)
  photoMime         String?
  deviceClass       DeviceClass         @default(CLASS_I)
  intendedPurpose   String?
  userProfile       String?
  patientPopulation String?
  indications       String?
  contraindications String?
  isSterile         Boolean             @default(false)
  sterilization     SterilizationMethod @default(NON_STERILE)
  hasMeasuringFn    Boolean             @default(false)
  containsSoftware  Boolean             @default(false)
  isInvasive        Boolean             @default(false)
  // Extended device characteristics that drive section / GSPR applicability.
  isImplantable           Boolean       @default(false) // implantable device (Art. 18 implant card, SSCP)
  isActive                Boolean       @default(false) // active device / electrically powered (IEC 60601)
  isReusable              Boolean       @default(false) // reusable surgical instrument (reprocessing validation)
  emitsRadiation          Boolean       @default(false) // emits ionising/non-ionising radiation (GSPR 16)
  administersMedicineOrEnergy Boolean    @default(false) // delivers/removes medicine or energy (GSPR 21)
  containsMedicinalSubstance Boolean     @default(false) // incorporates a medicinal substance (GSPR 12.1)
  containsBiologicalMaterial Boolean     @default(false) // materials of human/animal/microbial origin (GSPR 13.1)
  isAbsorbable            Boolean       @default(false) // absorbed by / dispersed in the body (GSPR 12.2)
  containsCmrOrEndocrine  Boolean       @default(false) // CMR / endocrine-disrupting substances (GSPR 10.4)
  containsNanomaterial    Boolean       @default(false) // contains/consists of nanomaterials (GSPR 10.6)
  isForLayUser            Boolean       @default(false) // intended for use by laypersons (GSPR 22)
  bodyContactDuration String?           // transient | short-term | long-term
  materials         String?
  packagingType     String?
  shelfLife         String?
  manufacturingProcess String?
  criticalSuppliers String?
  appliedStandards  String?
  complianceScore   Int                 @default(0) // 0-100
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?

  company           Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  technicalSections TechnicalFileSection[]
  gsprItems         GSPRItem[]
  riskItems         RiskItem[]
  riskManagementFile RiskManagementFile?
  clinicalEvaluation ClinicalEvaluation?
  pmsPlan           PMSPlan?
  pmcfPlan          PMCFPlan?
  ifuDocuments      IFUDocument[]
  labelDocuments    LabelDocument[]
  documents         Document[]
  uploadedFiles     UploadedFile[]
  auditFindings     AuditFinding[]
  capas             CAPA[]
  complaints        Complaint[]
  operationalRecords QmsOperationalRecord[]
  aiAnalyses        AIAnalysis[]
  composerDocuments ComposerDocument[]
  auditSessions     AuditSession[]
  designControlRecords DesignControlRecord[]
  cyberSecurityFile    CyberSecurityFile?
  softwareLifecycleFile SoftwareLifecycleFile?

  @@index([companyId])
}

// ---------------- Documents & Versioning ----------------

model Document {
  id          String            @id @default(cuid())
  productId   String?
  companyId   String?
  title       String
  category    String // e.g. "Technical File", "Risk", "CER"
  status      DocStatus         @default(MISSING)
  ownerName   String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?

  product     Product?          @relation(fields: [productId], references: [id], onDelete: Cascade)
  versions    DocumentVersion[]

  @@index([productId])
}

model DocumentVersion {
  id          String   @id @default(cuid())
  documentId  String
  version     String // v1.0, v1.1 ...
  changeNote  String?
  preparedBy  String?
  approvedBy  String?
  content     String?  @db.Text
  publishedAt DateTime?
  createdAt   DateTime @default(now())

  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model TechnicalFileSection {
  id            String    @id @default(cuid())
  productId     String
  key           String // mdr annex section key
  title         String
  order         Int       @default(0)
  status        DocStatus @default(MISSING)
  applicable    Boolean   @default(true) // false = not applicable to this device (auto by class/properties)
  naReason      String? // why the section is not applicable (e.g. "Non-sterile device")
  ownerName     String?
  content       String?   @db.Text
  annexRef      String? // "Annex II 1.1"
  issueDate     DateTime? // first publication date (fixed once set)
  revisionNo    Int       @default(0) // REV. NO (0 = first issue)
  revisionDate  DateTime? // date of the latest revision
  revisionHistoryJson Json? // [{ rev, date, by, note }]
  sectionExtrasJson   Json? // PMCF survey (plan) / survey results (report), etc.
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  evidenceLinks TechnicalFileEvidenceLink[]

  @@index([productId])
}

// ---------------- GSPR (MDR Annex I) ----------------

model GSPRItem {
  id                  String            @id @default(cuid())
  productId           String
  gsprNo              String // "1", "10.4" ...
  requirementSummary  String
  applicable          GsprApplicability @default(JUSTIFICATION)
  justification       String?
  evidenceDocument    String?
  evidenceManual      Boolean           @default(false)
  standardReference   String?
  complianceStatement String?
  status              DocStatus         @default(MISSING)
  aiGapComment        String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  product             Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  evidenceLinks       GSPREvidenceLink[]

  @@index([productId])
}

// ---------------- ISO 14971 Risk ----------------

model RiskItem {
  id                    String    @id @default(cuid())
  productId             String
  sequenceNo            Int       @default(0)
  riskNo                String?
  hazard                String
  sequenceOfEvents      String?
  hazardousSituation    String?
  harm                  String?
  riskSource            String?   @db.Text
  tableERef             String?
  initialSeverity       Int       @default(1) // 1-5
  initialProbability    Int       @default(1) // 1-5
  initialRiskLevel      RiskLevel @default(LOW)
  riskControlMeasure    String?
  residualSeverity      Int       @default(1)
  residualProbability   Int       @default(1)
  residualRiskLevel     RiskLevel @default(LOW)
  mitigations           Json?
  residualAssessment    String?   @db.Text
  benefitRiskJustification String?
  verificationOfControl String?
  linkedReferences      String? // IFU / Label / Design control links
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  product               Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  evidenceLinks         RiskEvidenceLink[]

  @@index([productId])
}

model RiskManagementFile {
  id                   String    @id @default(cuid())
  productId            String    @unique
  plan                 String?   @db.Text
  report               String?   @db.Text
  managementPolicy     String?   @db.Text
  annexAQuestions      String?   @db.Text
  annexARows           Json?
  planTableE1Rows      Json?
  planTableE2Rows      Json?
  planUploadedFileId     String?
